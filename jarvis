#!/usr/bin/env bash
# Jarvis Launcher — WQ7036AX Agent (OpenCode-derived fork)
# Sources provider config from external script if available.
set -euo pipefail

JARVIS_ROOT="$(cd "$(dirname "$0")" && pwd)"
BUN="$HOME/.bun/bin/bun"

# Source provider env if not already set
if [ -f "$JARVIS_ROOT/model.sh" ] && [ -z "${ANTHROPIC_BASE_URL:-}" ]; then
  case "${JARVIS_PROVIDER:-flash}" in
    flash|glm|kimi|qwen|xiaomi)
      source "$JARVIS_ROOT/model.sh" "$JARVIS_PROVIDER" 2>/dev/null || true
      ;;
  esac
fi

# Run the Jarvis TUI via the CLI package
exec "$BUN" run --cwd "$JARVIS_ROOT/packages/cli" src/index.ts "$@"
